@startuml
skinparam monochrome true
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam defaultFontName "Times New Roman"
skinparam defaultFontSize 14
skinparam ClassBackgroundColor White
skinparam ClassBorderColor Black
skinparam ArrowColor Black

class "Автор" as Author <<actor>>
class "Подписчик" as Subscriber <<actor>>
class "Владелец платформы" as Owner <<actor>>

class SubscriptionManager {
  +platformTreasury: address
  +platformFeeBps: uint16 = 2000
  +plans: mapping(bytes32 => Plan)
  +paidUntil: mapping(address => mapping(bytes32 => uint64))
  --
  +registerPlan(planKey, token, price, periodSeconds, acceptsNative)
  +updatePlan(planKey, token, price, periodSeconds, active, acceptsNative)
  +subscribe(planKey) payable
  +setPlatformTreasury(treasury)
  +setPlatformFeeBps(feeBps)
}

class Plan {
  +author: address
  +token: address
  +price: uint256
  +periodSeconds: uint64
  +active: bool
  +acceptsNative: bool
}

class SubscriptionPaidEvent {
  +planKey: bytes32
  +subscriber: address
  +author: address
  +token: address
  +amount: uint256
  +fee: uint256
  +paidUntil: uint64
}

class ERC20Token {
  +approve(spender, amount)
  +transferFrom(from, to, amount)
}

class BackendConfirmation {
  +getTransactionReceipt(txHash)
  +decode SubscriptionPaid
  +validate subscriber / planKey / amount
  +upsert entitlement
}

Author --> SubscriptionManager : registerPlan / updatePlan
Owner --> SubscriptionManager : setTreasury / setFee
Subscriber --> ERC20Token : approve(manager, price)\nfor ERC-20 plan
Subscriber --> SubscriptionManager : subscribe(planKey)\nmsg.value for native plan
SubscriptionManager *-- Plan : stores
SubscriptionManager --> ERC20Token : transferFrom\nfor ERC-20 payments
SubscriptionManager --> Author : transfers 80%
SubscriptionManager --> Owner : transfers 20%
SubscriptionManager --> SubscriptionPaidEvent : emits
BackendConfirmation --> SubscriptionPaidEvent : reads from receipt
BackendConfirmation --> SubscriptionManager : verifies manager address
@enduml
