@startuml
skinparam monochrome true
skinparam shadowing false
skinparam packageStyle rectangle
skinparam componentStyle rectangle
skinparam defaultFontName "Times New Roman"
skinparam defaultFontSize 14
skinparam ArrowColor Black
skinparam PackageBackgroundColor White
skinparam ComponentBackgroundColor White

package "frontend/src" {
    package "app" {
        component "router.tsx\npublic/private routes" as Router
        component "providers.tsx\nQueryClient, Wagmi" as Providers
    }

    package "pages" {
        component "HomePage" as HomePage
        component "AuthorPage" as AuthorPage
    }

    package "components" {
        component "PostFeed" as PostFeed
        component "SubscribeButton" as SubscribeButton
    }

    package "queries" {
        component "usePostsQuery" as PostQueries
        component "useSubscriptionPlansQuery" as PlanQueries
    }

    package "api" {
        component "PostsApi" as PostsApi
        component "SubscriptionPlansApi" as PlansApi
        component "Axios http client" as Axios
    }

    package "stores / hooks" {
        component "auth-store\nJWT, wallet state" as AuthStore
        component "useWalletSession\nnonce signing" as WalletSession
    }

    package "utils / web3" {
        component "erc20.ts\nallowance / approve" as ERC20
        component "subscriptions.ts\nmanager ABI calls" as Web3Subs
    }
}

Router --> HomePage
Router --> AuthorPage

HomePage --> PostFeed
AuthorPage --> SubscribeButton
SubscribeButton --> PlanQueries

PostFeed --> PostQueries

PostQueries --> PostsApi
PlanQueries --> PlansApi

PostsApi --> Axios
PlansApi --> Axios

WalletSession --> AuthStore
WalletSession --> Axios
SubscribeButton --> ERC20
SubscribeButton --> Web3Subs
Providers --> Router
@enduml
